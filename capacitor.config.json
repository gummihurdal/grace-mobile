{
  "appId": "day.graceforevery.app",
  "appName": "Grace",
  "webDir": "www",
  "android": {
    "backgroundColor": "#020A1E",
    "allowMixedContent": false,
    "overScrollMode": "never"
  },
  "ios": {
    "backgroundColor": "#020A1E",
    "contentInset": "always",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#020A1E",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#020A1E"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#C9A43A",
      "sound": "default"
    }
  }
}
