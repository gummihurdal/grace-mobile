{
  "appId": "day.graceforevery.app",
  "appName": "Grace",
  "webDir": "www",
  "android": {
    "backgroundColor": "#0a0a0a",
    "allowMixedContent": false,
    "overScrollMode": "never"
  },
  "ios": {
    "backgroundColor": "#0a0a0a",
    "contentInset": "always",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a"
    }
  }
}
